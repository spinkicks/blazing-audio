rules_version = '2';

// Storage is set up (Blaze) but not yet used by the MVP. Lock it down: a signed-in
// user may only read/write their own folder; everything else is denied.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
