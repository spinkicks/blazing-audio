# Firebase web app config (Project settings -> Your apps -> SDK setup and configuration).
# Copy this file to ".env.local" and fill in the values from your Firebase project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to point the app at the local Firebase Emulator Suite instead of the cloud.
# (Run `npm run emulators` in another terminal first.) This also routes the AI
# callable functions to the local Functions emulator (port 5001).
VITE_USE_FIREBASE_EMULATORS=false

# NOTE: The OpenAI API key is NOT a client env var. It lives only on the server
# as a Firebase secret, so it is never shipped in the browser bundle. Set it with:
#   npx firebase-tools@latest functions:secrets:set OPENAI_API_KEY
# Until it is set, the AI features fail gracefully with a "not configured yet" message.
# Optionally pin the model via the OPENAI_MODEL env var on the function (default: gpt-4o-mini).
