rules_version = '2';

// A learner can read and write only their own profile and lesson progress.
// Lesson content ships in the app bundle, so it needs no Firestore rules.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /lessonProgress/{lessonId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-concept spaced-repetition memory: owner-only, same as lessonProgress.
      match /conceptMemory/{conceptId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // End-of-course capstone submissions: owner-only, same as lessonProgress.
      match /capstone/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // AI-generated review questions are written only by Cloud Functions (Admin
      // SDK, which bypasses rules). The learner may read their own cached sets;
      // client writes stay denied so generated answer keys can't be tampered with.
      match /reviewQuestions/{topicId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }

      // Intentionally NO rule for `reviewQuestionsKeys/*` (fill-in-the-blank
      // grading rubrics) or `aiUsage/*` (daily quota counters): they are written
      // and read only by the Admin SDK and must never be client-readable.
    }

    // Opt-in leaderboard: any signed-in user may read; a user may write only their
    // own entry, restricted to the expected fields (client-written, see spec section 10).
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.keys().hasOnly(['alias', 'xp', 'updatedAt'])
        && request.resource.data.alias is string
        && request.resource.data.alias.size() > 0
        && request.resource.data.alias.size() <= 24
        && request.resource.data.xp is number;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
